# Copy this file to secrets/.env and fill in real values.
# The .env file is gitignored and never committed.

# Database user password (required)
H2_PASSWORD=change_me_to_a_strong_password

# AES file encryption key for database at rest (required)
H2_FILE_PASSWORD=change_me_to_another_strong_password

# To rotate H2_PASSWORD: move current value here, set new H2_PASSWORD above.
# After one successful startup, remove this line.
# H2_PRIOR_PASSWORD=
